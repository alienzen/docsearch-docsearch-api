# ── docsearch-api — Variables d'environnement ────────────────

ES_HOST=http://es01:9200
ES_INDEX=documents
REDIS_HOST=redis

# Simule un utilisateur en développement, sans SSO (laisser vide en prod)
DEV_USER=

# ── LDAP / Active Directory ──────────────────────────────────
# LDAP_ENABLED=false : filtrage ACL uniquement sur les groupes POSIX
LDAP_ENABLED=false
LDAP_HOST=ldap://dc01.domaine.gouv.fr
LDAP_BASE=dc=domaine,dc=gouv,dc=fr
LDAP_BINDDN=cn=svc-docsearch,ou=services,dc=domaine,dc=gouv,dc=fr
LDAP_PASS=changeme

# ── Panneau d'administration (/admin) ────────────────────────
# Groupe LDAP/AD autorisé à accéder au panneau d'administration.
# Nécessite LDAP_ENABLED=true. Vide = accès admin désactivé.
ADMIN_GROUP=docsearch-admins

# ⚠️  DANGER — tests locaux uniquement, jamais en production : contourne
# TOUT contrôle d'accès sur /admin. Voir docsearch-infra/.env.example.
ADMIN_AUTH_DISABLED=false

# ── Accès à l'application (toutes les pages) ──────────────────
# Groupe LDAP/AD autorisé à consulter DocSearch (index.html, chat.html,
# admin.html...). Nécessite LDAP_ENABLED=true. Vide = accès désactivé.
ACCESS_GROUP=docsearch-users

# ⚠️  DANGER — tests locaux uniquement, jamais en production : contourne
# TOUT contrôle d'accès sur l'ensemble des pages (voir access_auth.py).
ACCESS_AUTH_DISABLED=false

DOCKER_UID=1000
